+			outer:
+			for (int i = 0; i <= data.length - pattern.length; i++)
+			{
+				for (int j = 0; j < pattern.length; j++)
+				{
+					if (data[i + j] != pattern[j])
+						continue outer;
+				}
+				return i;
+			}
+			return -1;
+		}
+	}

 
